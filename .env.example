# Copy this file to .env and fill in your credentials.
# .env is listed in .gitignore and will NOT be committed.

SONNEN_USERNAME=your@email.com
SONNEN_PASSWORD=YourPassword

POLL_INTERVAL_SECONDS=300
SERVER_HOST=0.0.0.0
SERVER_PORT=8099

# Set to "true" to log the full scraped payload after each poll
LOG_SCRAPED_DATA=false
